; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Egg timer (realistically a shin ramen timer)"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=400
window/size/viewport_height=464
window/size/resizable=false
window/size/borderless=true
window/size/transparent=true
window/size/no_focus=true
window/stretch/mode="viewport"
window/stretch/scale=8.0
window/per_pixel_transparency/allowed=true

[dotnet]

project/assembly_name="Egg timer (realistically a shin ramen timer)"

[input]

SubtractMinute={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194435,"key_label":0,"unicode":45,"location":0,"echo":false,"script":null)
]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
gl_compatibility/driver.windows="opengl3_angle"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.3019608, 0.3019608, 0.3019608, 0)
viewport/transparent_background=true
2d/snap/snap_2d_vertices_to_pixel=true
